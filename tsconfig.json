{
  "extends": "@react-native/typescript-config",
  "compilerOptions": {
    "jsx": "react",
    "types": [
      "jest",
      "nativewind/types"
    ],
    "baseUrl": ".",
    "paths": {
      "@/*": ["./*"],
      "@/components/*": ["./components/*"],
      "@/utils/*": ["./utils/*"]
    },
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    "nativewind-env.d.ts",
    "types/**/*.ts"
  ],
  "exclude": [
    "**/node_modules",
    "**/Pods"
  ]
}
